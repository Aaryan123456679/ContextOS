# ContextOS Configuration

# Environment Settings
ENV=development
DEBUG=true
PROJECT_NAME="ContextOS"

# API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Configurations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# Qdrant Vector DB
QDRANT_URL=https://your-qdrant-instance.aws.qdrant.io:6333
QDRANT_KEY=your-qdrant-api-key-here

# Upstash Redis
UPSTASH_REDIS_URL=redis://default:your-redis-password@your-redis-instance.upstash.io:6379

# Cryptography
ENCRYPTION_KEY=generate-32-byte-hex-key-here
